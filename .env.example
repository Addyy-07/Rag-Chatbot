# Environment Variables — DocChat AI
# ────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# ==============================================================================
# 💳 PAYMENT CONFIGURATION (Razorpay)
# ==============================================================================
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_PLAN_MONTHLY=plan_test_monthly
RAZORPAY_PLAN_YEARLY=plan_test_yearly

# ==============================================================================
# 📧 EMAIL / SMTP CONFIGURATION
# ==============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your-email@gmail.com

# ==============================================================================
# 🧠 LLM & VECTOR DATABASE CONFIGURATION
# ==============================================================================

# ── Pinecone Vector Database ──────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=rag-chatbot-free
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_METRIC=cosine

# ── Groq LLM ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here

# Authentication & Database
MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=rag_chatbot_db
JWT_SECRET_KEY=super-secret-jwt-key-please-change-in-prod
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.0
GROQ_MAX_TOKENS=512

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Ingestion Tuning ──────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Retrieval Tuning ──────────────────────────────────────────────────────────
RETRIEVER_TOP_K=3
RETRIEVER_CONTEXT_MAX_CHARS=500

# ── Chat History Tuning ───────────────────────────────────────────────────────
CHAT_HISTORY_WINDOW=2
CHAT_HISTORY_MAX_CHARS=200

# ── App Metadata ──────────────────────────────────────────────────────────────
APP_TITLE=DocChat AI
APP_ICON=🧠
APP_VERSION=1.0.0
